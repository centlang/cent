with std::ffi;
with c;

type Vec2 {
    x: f64,
    y: f64,
}

for Vec2 {
    pub fn length_squared(self: Self) f64 {
        return self.x * self.x + self.y * self.y;
    }

    pub fn length(self: Self) f64 {
        return c::sqrt(self.length_squared());
    }
}

fn main() {
    let v = Vec2 { x: 1.0, y: 1.0 };

    c::printf(ffi::as_cstr("Vec2 { x: %f, y: %f }:\n\0"), v.x, v.y);
    c::printf(ffi::as_cstr("  length: %f\n\0"), v.length());
}
