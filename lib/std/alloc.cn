with c;

pub fn(<T>) alloc() ?*mut T {
    return c::malloc(core::mem::sizeof(<T>)()) as ?*mut T;
}

pub fn(<T>) alloc_n(size: usize) ?[]mut T {
    let data = c::malloc(size * core::mem::sizeof(<T>)());

    if data == null {
        return null;
    }

    return core::mem::as_mut_slice(data.! as *mut T, size);
}

pub fn(<T>) free(ptr: *mut T) {
    c::free(ptr as *mut c::void);
}

pub fn(<T>) free_n(slice: []mut T) {
    c::free(slice.ptr as *mut c::void);
}
