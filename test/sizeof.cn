fn main() {
    core::assert(core::mem::sizeof(<i32>)() == 4);
    core::assert(core::mem::sizeof(<i64>)() == 8);
    core::assert(core::mem::sizeof(<i8>)() == 1);

    core::assert(core::mem::sizeof(<u32>)() == 4);
    core::assert(core::mem::sizeof(<u64>)() == 8);
    core::assert(core::mem::sizeof(<u8>)() == 1);

    core::assert(core::mem::sizeof(<f32>)() == 4);
    core::assert(core::mem::sizeof(<f64>)() == 8);

    core::assert(core::mem::sizeof(<bool>)() == 1);

    core::assert(core::mem::sizeof(<*u8>)() == core::mem::sizeof(<*mut u8>)());
    core::assert(core::mem::sizeof(<*u8>)() == core::mem::sizeof(<usize>)());
}
